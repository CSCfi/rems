    "karma": "^6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-cljs-test": "0.1.0",
    "karma-junit-reporter": "2.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-select": "^5.10.2",
    "shadow-cljs": "^3.3.6"
  }
}
